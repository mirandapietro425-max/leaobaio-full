# ──────────────────────────────────────────────────────────────
#  LEÃO BAIO — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────────────────────────

# Segurança da sessão (use qualquer string longa e aleatória)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa_aqui

# Ambiente
NODE_ENV=development

# Porta (Render define automaticamente)
PORT=3000

# ── Turso (banco de dados) ─────────────────────────────────────
# Crie seu banco em: https://turso.tech
# 1. Instale a CLI: brew install tursodatabase/tap/turso  (ou npm i -g @turso/cli)
# 2. turso auth login
# 3. turso db create leaobaio
# 4. turso db show leaobaio          → copie a URL
# 5. turso db tokens create leaobaio → copie o token
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu_token_aqui

# ── Cloudinary (armazenamento de imagens) ─────────────────────
# Crie uma conta gratuita em: https://cloudinary.com
# Painel → Settings → API Keys
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=seu_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# Stripe (pagamentos)
# Crie conta em: https://stripe.com
# Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook: Stripe Dashboard -> Developers -> Webhooks -> Add endpoint
# URL: https://seu-site.onrender.com/api/webhooks/stripe
# Evento: payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (confirmacao de pedidos)
# Use uma conta Gmail com "Senha de app" ativada
# Google Account -> Seguranca -> Verificacao 2 etapas -> Senhas de app
EMAIL_USER=seu@gmail.com
EMAIL_PASS=senha_de_app_16_caracteres
